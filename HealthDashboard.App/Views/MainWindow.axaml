<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HealthDashboard.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="HealthDashboard.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Health Tracker &amp; Workout Dashboard"
        Width="800"
        Height="500"
        WindowStartupLocation="CenterScreen"
        Background="#11111B">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <!-- Background Gradient -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#0F0C20" Offset="0.0"/>
                    <GradientStop Color="#15102A" Offset="0.5"/>
                    <GradientStop Color="#1E1E2E" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Main Content Area -->
        <Grid RowDefinitions="Auto,*,Auto" Margin="30">
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
                <TextBlock Text="HEALTH &amp; WORKOUTS DASHBOARD" 
                           FontSize="28" 
                           FontWeight="Black" 
                           Foreground="#F5C2E7"
                           LetterSpacing="2"/>
                <TextBlock Text="Manage your workouts, metrics, and athletic progression in one modern interface." 
                           FontSize="14" 
                           Foreground="#A6ADC8"/>
                <Border Height="2" Background="#45475A" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Main Feature Card -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,20">
                <!-- Left panel: Welcome / Greeting -->
                <StackPanel Grid.Column="0" Spacing="15" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding Greeting}" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#FFFFFF" 
                               TextWrapping="Wrap"/>

                    <!-- Latest Calculated TDEE Display Card -->
                    <Border Background="#1E1E2E"
                            BorderBrush="#A6E3A1"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="15"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="3">
                            <TextBlock Text="CURRENT COMPUTED TDEE" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Foreground="#A6E3A1" 
                                       LetterSpacing="1"/>
                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                <TextBlock Text="{Binding LatestTdeeCalculated}" 
                                           FontSize="32" 
                                           FontWeight="Black" 
                                           Foreground="#FFFFFF"/>
                                <TextBlock Text="kcal/day" 
                                           FontSize="14" 
                                           Foreground="#A6ADC8" 
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Ready to analyze your training? Import your workout history from Hevy and your daily summaries from Cronometer to calculate TDEE, track muscle groups, analyze set volumes, and synchronize heart rate metrics." 
                               FontSize="13" 
                               Foreground="#CDD6F4" 
                               LineHeight="20"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Right panel: CSV Import Action Card -->
                <Border Grid.Column="1" 
                        Background="#1E1E2E" 
                        BorderBrush="#F5C2E7" 
                        BorderThickness="1" 
                        CornerRadius="16" 
                        Padding="25"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="15" HorizontalAlignment="Center">
                        <TextBlock Text="Ingest Daily Summaries &amp; Workouts" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#F5C2E7"
                                   HorizontalAlignment="Center"/>
                        
                        <TextBlock Text="Import a Hevy CSV export to integrate workout details, or a Cronometer daily summaries CSV to integrate daily nutrition &amp; weight logs." 
                                   FontSize="12" 
                                   Foreground="#A6ADC8" 
                                   TextAlignment="Center" 
                                   TextWrapping="Wrap"/>

                        <StackPanel Spacing="10">
                            <Button Command="{Binding ImportHevyCsvCommand}"
                                    Background="#F5C2E7"
                                    Foreground="#11111B"
                                    FontWeight="Bold"
                                    FontSize="13"
                                    Padding="20,10"
                                    CornerRadius="8"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="🏋️" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Import Hevy CSV" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ImportCronoCsvCommand}"
                                    Background="#89B4FA"
                                    Foreground="#11111B"
                                    FontWeight="Bold"
                                    FontSize="13"
                                    Padding="20,10"
                                    CornerRadius="8"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="🍎" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Import Cronometer CSV" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Footer: Status Bar -->
            <Border Grid.Row="2" 
                    Background="#1E1E2E" 
                    BorderBrush="#313244" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="12,10">
                <Grid ColumnDefinitions="Auto,*">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#A6E3A1"/>
                        <TextBlock Text="System Status:" FontSize="12" FontWeight="Bold" Foreground="#89B4FA" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding StatusText}" 
                               FontSize="12" 
                               Foreground="#CDD6F4" 
                               Margin="8,0,0,0" 
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
